    {
      "concept": "Reductio ad Absurdum",
      "description": "Zeno’s signature method: assume the opponent’s view and show it leads to contradiction."
    },
    {
      "concept": "Defense of Parmenides",
      "description": "All plurality and change are illusions; only the One truly exists."
    },
    {
      "concept": "Infinite Divisibility",
