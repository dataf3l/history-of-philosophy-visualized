    {
      "concept": "Determinism",
      "description": "His surviving fragment: 'Nothing happens in vain, but everything from a reason and by necessity.'"
    },
    {
      "concept": "Atomic Motion",
      "description": "Atoms move eternally and inherently; no divine mover or cosmic mind is required."
    },
    {
      "concept": "Cosmogenesis",
      "description": "Worlds form when a vast void is stirred into a vortex, causing atoms to collide and interlock based on shape."
    }
