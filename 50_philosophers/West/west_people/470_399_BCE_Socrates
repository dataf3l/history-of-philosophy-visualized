  "impact": {
    "immediate": "Polarizing figure in Athens; admired by youth, distrusted by authorities; executed for impiety and corrupting the youth.",
    "longTerm": "Foundation of Western ethics and epistemology; central figure for Plato and, through him, the entire philosophical canon.",
    "modernRelevance": "Prototype of the philosophical life: critical inquiry, moral courage, and intellectual humility."
  },
  "critiques": {
    "famousObjections": "Accused of sophistry, corrupting youth, and undermining traditional religion.",
