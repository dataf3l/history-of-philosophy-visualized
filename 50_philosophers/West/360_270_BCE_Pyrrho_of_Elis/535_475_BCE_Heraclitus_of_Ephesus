      "concept": "The Logos",
      "description": "A universal rational order that structures all things, though most people fail to perceive it."
    },
    {
      "concept": "Fire as the Arche",
      "description": "Fire is the fundamental principle because it is dynamic, transformative, and ever-moving."
    },
    {
      "concept": "War/Strife as Father",
      "description": "Conflict between opposites is necessary for existence; tension sustains the cosmos."
    }
  ],
  "methodStyle": {
    "approach": "Aphoristic and Paradoxical",
    "notes": "Wrote in riddles to provoke insight; truth is hidden yet accessible to those attuned to the Logos."
  },
